<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvAssignTracking"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColor="@color/lbc_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Select Rider *"
        android:textColor="@color/lbc_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerRider"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/spinner_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:id="@+id/tvNoRiders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_warning"
        android:padding="10dp"
        android:text="⚠️ No riders registered at this branch. Ask your admin to add riders."
        android:textColor="#856404"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
