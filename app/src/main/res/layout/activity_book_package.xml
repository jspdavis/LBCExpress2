<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lbc_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/lbc_red"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/tvBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LBC"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step indicator -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <TextView android:layout_width="30dp" android:layout_height="30dp"
                        android:background="@drawable/step_done" android:gravity="center"
                        android:text="✓" android:textColor="@color/white" android:textStyle="bold"/>
                    <TextView android:layout_width="30dp" android:layout_height="30dp"
                        android:background="@drawable/step_done" android:gravity="center"
                        android:layout_marginStart="4dp"
                        android:text="✓" android:textColor="@color/white" android:textStyle="bold"/>
                    <TextView android:layout_width="30dp" android:layout_height="30dp"
                        android:background="@drawable/step_active" android:gravity="center"
                        android:layout_marginStart="4dp"
                        android:text="3" android:textColor="@color/white" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" android:layout_weight="1"
                        android:text="Package Details"
                        android:textColor="@color/lbc_text_primary" android:textStyle="bold"/>
                    <TextView android:layout_width="30dp" android:layout_height="30dp"
                        android:background="@drawable/step_inactive" android:gravity="center"
                        android:text="4" android:textColor="@color/lbc_gray" android:textStyle="bold"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Package" android:textColor="@color/lbc_text_primary"
                        android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Item Name *" android:textColor="@color/lbc_text_secondary"
                        android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" app:boxStrokeColor="@color/lbc_red">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etItemName"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:hint="e.g. Laptop, Documents"
                            android:inputType="text" android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Item Value *" android:textColor="@color/lbc_text_secondary"
                        android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" app:boxStrokeColor="@color/lbc_red"
                        app:prefixText="PHP ">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etItemValue"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:hint="0.00" android:inputType="numberDecimal" android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Package Type *" android:textColor="@color/lbc_text_secondary"
                        android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <Spinner android:id="@+id/spinnerPackageType"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:layout_marginBottom="4dp" android:background="@drawable/spinner_bg"
                        android:paddingStart="12dp" android:paddingEnd="12dp"/>

                    <TextView android:id="@+id/tvPackageHint"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_package_hint"
                        android:padding="10dp"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:visibility="gone"/>

                    <!-- Lead Time -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Preferred delivery lead time *"
                        android:textColor="@color/lbc_text_primary"
                        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                    <RadioGroup android:id="@+id/rgLeadTime"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">
                        <RadioButton android:id="@+id/rbRush" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Rush"
                            android:checked="true" android:buttonTint="@color/lbc_red"/>
                        <RadioButton android:id="@+id/rbRegular" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Regular"
                            android:buttonTint="@color/lbc_red"/>
                    </RadioGroup>

                    <!-- COD -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Use LBC's Payment Collection (COP/COD) *"
                        android:textColor="@color/lbc_text_primary"
                        android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                    <RadioGroup android:id="@+id/rgCod"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">
                        <RadioButton android:id="@+id/rbCodYes" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Yes"
                            android:buttonTint="@color/lbc_red"/>
                        <RadioButton android:id="@+id/rbCodNo" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="No"
                            android:checked="true" android:buttonTint="@color/lbc_red"/>
                    </RadioGroup>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBack"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp" android:layout_weight="1"
                            android:padding="14dp" android:text="Back"
                            android:textColor="@color/lbc_red"
                            app:cornerRadius="8dp" app:strokeColor="@color/lbc_red"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNext"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:backgroundTint="@color/lbc_red"
                            android:padding="14dp" android:text="Next"
                            android:textColor="@color/white" android:textStyle="bold"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
